# ── Server ──────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── JWT (Lange, zufällige Strings verwenden!) ───────
JWT_SECRET=aendere-mich-zu-einem-langen-zufaelligen-geheimnis
REFRESH_SECRET=aendere-mich-zu-einem-anderen-langen-geheimnis

# ── PostgreSQL Datenbank ─────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=letschat
DB_USER=postgres
DB_PASSWORD=dein_passwort
DB_SSL=false
# Für Render/Railway/Heroku: DB_SSL=true

# ── CORS (kommagetrennte Origins) ────────────────────
# Lokal + Electron:
CORS_ORIGIN=http://localhost:5173,app://.
# Produktion (eigene Domain eintragen):
# CORS_ORIGIN=https://deine-domain.com,app://.
